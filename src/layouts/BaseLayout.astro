---
import '../styles/global.css';
import '../styles/navbar.css';
import '../styles/filterbar.css';
import '../styles/home.css';
import '../styles/postcard.css';
import '../styles/post.css';
import '../styles/sharebuttons.css';
import '../styles/postextras.css';

import Mermaid from '../components/Mermaid.astro';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
  lang?: 'pt-BR' | 'en';
  hasMermaid?: boolean;
  ogImagePath?: string;
  alternatePt?: string;
  alternateEn?: string;
}

const {
  title,
  description,
  type = 'website',
  publishedDate,
  modifiedDate,
  tags = [],
  lang = 'pt-BR',
  hasMermaid = false,
  ogImagePath = '/og-default.png',
  alternatePt,
  alternateEn,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(ogImagePath, Astro.site).href;
const siteName = 'CommandLinux';
const authorUrl = new URL('/sobre/', Astro.site).href;
const authorImage = new URL('/author-cesar-santos.svg', Astro.site).href;

const ogLocale = lang === 'en' ? 'en_US' : 'pt_BR';

const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        url: canonical,
        datePublished: publishedDate?.toISOString(),
        dateModified: (modifiedDate ?? publishedDate)?.toISOString(),
        image: ogImage,
        keywords: tags.join(', '),
        author: {
          '@type': 'Person',
          name: 'Cesar Santos',
          url: authorUrl,
          image: authorImage,
        },
        publisher: {
          '@type': 'Person',
          name: 'Cesar Santos',
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteName,
        url: Astro.site?.href,
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/logo.svg?v=2" />
    <link rel="alternate icon" href="/logo.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternatePt && <link rel="alternate" hreflang="pt-BR" href={new URL(alternatePt, Astro.site)} />}
    {alternateEn && <link rel="alternate" hreflang="en" href={new URL(alternateEn, Astro.site)} />}
    {alternatePt && <link rel="alternate" hreflang="x-default" href={new URL(alternatePt, Astro.site)} />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    {alternatePt && alternateEn && <meta property="og:locale:alternate" content={lang === 'en' ? 'pt_BR' : 'en_US'} />}
    {type === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    {type === 'article' && (modifiedDate ?? publishedDate) && <meta property="article:modified_time" content={(modifiedDate ?? publishedDate)?.toISOString()} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={new URL('rss.xml', Astro.site)}
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <slot />
    {hasMermaid && <Mermaid />}
    <Analytics />
  </body>
</html>
