---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.tsx';
import CopyCode from '../../components/CopyCode.astro';

const catColor = {
  KUBERNETES: 'var(--c-kubernetes)', DOCKER: 'var(--c-docker)',
  TERRAFORM: 'var(--c-terraform)', LINUX: 'var(--c-linux)',
  'CI/CD': 'var(--c-cicd)', 'SYSTEM DESIGN': 'var(--c-sysdesign)',
  CLOUD: 'var(--c-cloud)',
};

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const color = catColor[post.data.category] ?? 'var(--accent-hover)';
const formattedDate = post.data.date.toLocaleDateString('pt-BR', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// relacionados: mesma categoria primeiro, completa com recentes; máx 3
const all = (await getCollection('posts', ({ data }) => !data.draft))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sameCat = all.filter((p) => p.data.category === post.data.category);
const rest = all.filter((p) => p.data.category !== post.data.category);
const related = [...sameCat, ...rest].slice(0, 3);
---
<BaseLayout title={`${post.data.title} — CommandLinux`}
  description={post.data.description} type="article"
  publishedDate={post.data.date} tags={post.data.tags}>
  <div class="section-wrap post-page" style={`--post-color:${color}`}>
    <a class="post-back" href="/">cd ..</a>
    <header class="post-header">
      <span class="post-type" style={`color:${color};border:1px solid ${color}`}>{post.data.category}</span>
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>
    <ShareButtons client:load title={post.data.title} />
    <CopyCode />

    {related.length > 0 && (
      <section class="related">
        <p class="related-label">// continue lendo</p>
        <div class="related-grid">
          {related.map((p) => (
            <a class="related-card" href={`/posts/${p.id}/`}
               style={`--post-color:${catColor[p.data.category] ?? 'var(--accent-hover)'}`}>
              <span class="related-cat">{p.data.category}</span>
              <span class="related-title">{p.data.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
