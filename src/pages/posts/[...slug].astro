---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ShareButtons from '../../components/ShareButtons.tsx';
import CopyCode from '../../components/CopyCode.astro';
import Newsletter from '../../components/Newsletter.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import Reactions from '../../components/Reactions.tsx';

const categoryColors: Record<string, string> = {
  KUBERNETES: 'var(--c-kubernetes)',
  DOCKER: 'var(--c-docker)',
  TERRAFORM: 'var(--c-terraform)',
  LINUX: 'var(--c-linux)',
  'CI/CD': 'var(--c-cicd)',
  'SYSTEM DESIGN': 'var(--c-sysdesign)',
  CLOUD: 'var(--c-cloud)',
  NETWORKING: 'var(--c-networking)',
  'SEGURANÇA CIBERNÉTICA': 'var(--c-cyber-security)',
  'CYBER SECURITY': 'var(--c-cyber-security)',
};

const normalizeCategory = (category: string) =>
  String(category).trim().toUpperCase();

export async function getStaticPaths() {
  const portuguesePosts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'pt',
  );

  const englishPosts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'en',
  );

  const englishIds = new Set(englishPosts.map((post) => post.id));

  return portuguesePosts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
      enHref: englishIds.has(`en/${post.id}`)
        ? `/en/posts/${post.id}/`
        : undefined,
    },
  }));
}

const { post, enHref } = Astro.props;
const { Content } = await render(post);
const hasMermaid = /```mermaid\b/.test(post.body);

const category = normalizeCategory(post.data.category);

const postColor =
  categoryColors[category] ?? 'var(--accent-hover)';

const formattedDate = post.data.date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const all = (
  await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'pt',
  )
)
  .filter((item) => item.id !== post.id)
  .sort(
    (a, b) =>
      b.data.date.valueOf() - a.data.date.valueOf(),
  );

const sameCategory = all.filter(
  (item) =>
    normalizeCategory(item.data.category) === category,
);

const remainingPosts = all.filter(
  (item) =>
    normalizeCategory(item.data.category) !== category,
);

const related = [
  ...sameCategory,
  ...remainingPosts,
].slice(0, 3);

const seriesPosts = post.data.series
  ? [...all, post]
      .filter((item) => item.data.series === post.data.series)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
const seriesIndex = seriesPosts.findIndex((item) => item.id === post.id);
const previousInSeries = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : undefined;
const nextInSeries = seriesIndex >= 0 ? seriesPosts[seriesIndex + 1] : undefined;
---

<BaseLayout
  lang="pt-BR"
  title={`${post.data.title} — CommandLinux`}
  description={post.data.description}
  type="article"
  publishedDate={post.data.date}
  modifiedDate={post.data.updatedDate ?? post.data.date}
  tags={post.data.tags}
  hasMermaid={hasMermaid}
  ogImagePath={`/og/pt/${post.id}.png`}
  alternatePt={`/posts/${post.id}/`}
  alternateEn={enHref}
>
  <Navbar
    language="pt"
    ptHref={`/posts/${post.id}/`}
    enHref={enHref}
  />

  <div
    class="section-wrap post-page"
    style={`--post-color: ${postColor};`}
  >
    <ReadingProgress label="Progresso da leitura" />
    <a class="post-back" href="/">cd ..</a>

    <header class="post-header">
      <span
        class="post-type"
        style={`color: ${postColor}; border-color: ${postColor};`}
      >
        {category}
      </span>

      <h1 class="post-title">
        {post.data.title}
      </h1>

      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
        <span aria-hidden="true">·</span>
        <a href="/sobre/" rel="author">Cesar Santos</a>
      </div>

      <div class="post-tags" aria-label="Tags do artigo">
        {post.data.tags.map((tag) => (
          <a class="post-tag-link" href={`/?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
        ))}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    {post.data.series && (
      <nav class="series-nav" aria-label={`Série ${post.data.series}`}>
        <div class="series-heading">
          <span>// série</span>
          <strong>{post.data.series}</strong>
          <small>Parte {post.data.seriesOrder ?? seriesIndex + 1} de {seriesPosts.length}</small>
        </div>
        <div class="series-links">
          {previousInSeries ? <a href={`/posts/${previousInSeries.id}/`}>← {previousInSeries.data.title}</a> : <span />}
          {nextInSeries && <a href={`/posts/${nextInSeries.id}/`}>{nextInSeries.data.title} →</a>}
        </div>
      </nav>
    )}

    <ShareButtons
      client:load
      title={post.data.title}
      description={post.data.description}
      category={category}
      locale="pt"
    />

    <Reactions client:load postId={`pt:${post.id}`} locale="pt" />

    <CopyCode />

    <Newsletter />

    {
      related.length > 0 && (
        <section class="related">
          <p class="related-label">
            // continue lendo
          </p>

          <div class="related-grid">
            {related.map((item) => (
              <a
                class="related-card"
                href={`/posts/${item.id}/`}
              >
                <span class="related-cat">
                  {normalizeCategory(item.data.category)}
                </span>

                <span class="related-title">
                  {item.data.title}
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
