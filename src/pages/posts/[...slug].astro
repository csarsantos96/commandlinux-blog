---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ShareButtons from '../../components/ShareButtons.tsx';
import CopyCode from '../../components/CopyCode.astro';
import Newsletter from '../../components/Newsletter.astro';


export async function getStaticPaths() {
  const portuguesePosts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'pt',
  );

  const englishPosts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'en',
  );

  const englishIds = new Set(englishPosts.map((post) => post.id));

  return portuguesePosts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      enHref: englishIds.has(`en/${post.id}`)
        ? `/en/posts/${post.id}/`
        : undefined,
    },
  }));
}

const { post, enHref } = Astro.props;
const { Content } = await render(post);



const formattedDate = post.data.date.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const all = (await getCollection(
  'posts',
  ({ data }) => !data.draft && data.language === 'pt',
))
  .filter((item) => item.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const sameCategory = all.filter(
  (item) => item.data.category === post.data.category,
);

const remainingPosts = all.filter(
  (item) => item.data.category !== post.data.category,
);

const related = [...sameCategory, ...remainingPosts].slice(0, 3);
---

<BaseLayout
  lang="pt-BR"
  title={`${post.data.title} — CommandLinux`}
  description={post.data.description}
  type="article"
  publishedDate={post.data.date}
  tags={post.data.tags}
>
  <Navbar
    language="pt"
    ptHref={`/posts/${post.id}/`}
    enHref={enHref}
  />

  <div class="section-wrap post-page" style={`--post-color:${color}`}>
    <a class="post-back" href="/">cd ..</a>

    <header class="post-header">
      <span class="post-type">{post.data.category}</span>

      <h1 class="post-title">{post.data.title}</h1>

      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <ShareButtons client:load title={post.data.title} />
    <CopyCode />
    <Newsletter />

    {
      related.length > 0 && (
        <section class="related">
          <p class="related-label">// continue lendo</p>

          <div class="related-grid">
            {related.map((item) => (
              <a
                class="related-card"
                href={`/posts/${item.id}/`}
                
              >
                <span class="related-cat">{item.data.category}</span>
                <span class="related-title">{item.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>