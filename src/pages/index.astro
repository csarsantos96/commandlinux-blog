---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import PostFilter from '../components/PostFilter.tsx';

const raw = await getCollection(
  'posts',
  ({ data }) => !data.draft && data.language === 'pt',
);

const posts = raw
  .map((post) => {
    const words = post.body.split(/\s+/).filter(Boolean).length;

    return {
      id: post.id,
      slug: post.id,
      title: post.data.title,
      description: post.data.description,
      date: post.data.date.toISOString().slice(0, 10),
      category: post.data.category.toUpperCase(),
      tags: post.data.tags,
      series: post.data.series,
      part: post.data.part ?? post.data.seriesOrder,
      totalParts: post.data.totalParts,
      readingMinutes: Math.max(1, Math.round(words / 200)),
    };
  })
  .sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout
  lang="pt-BR"
  title="CommandLinux — DevOps, Cloud Native e o que roda por baixo"
  description="Kubernetes, Docker, Terraform, Linux e system design — anotações de campo de quem está construindo o caminho até o CKA."
>
  <Navbar language="pt" ptHref="/" enHref="/en/" />

  <section class="section-wrap">
    <header class="home-hero">
      <div class="hero-status">
        <span class="status-dot"></span>
        NOVOS POSTS TODA SEMANA
      </div>

      <div class="section-tag">blog</div>

      <h1 class="section-title">
        DevOps, Cloud Native<br />
        e o que roda por baixo.
      </h1>

      <p class="home-sub">
        Kubernetes, Docker, Terraform, Linux e system design — anotações de
        campo de quem está construindo o caminho até o CKA.
      </p>
    </header>

    <PostFilter
      client:load
      posts={posts}
      locale="pt"
      postBasePath="/posts"
    />
  </section>
</BaseLayout>
