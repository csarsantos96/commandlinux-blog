---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import ShareButtons from '../../../components/ShareButtons.tsx';
import CopyCode from '../../../components/CopyCode.astro';
import ReadingProgress from '../../../components/ReadingProgress.astro';
import Reactions from '../../../components/Reactions.tsx';

const categoryColors: Record<string, string> = {
  KUBERNETES: 'var(--c-kubernetes)',
  DOCKER: 'var(--c-docker)',
  TERRAFORM: 'var(--c-terraform)',
  LINUX: 'var(--c-linux)',
  'CI/CD': 'var(--c-cicd)',
  'SYSTEM DESIGN': 'var(--c-sysdesign)',
  CLOUD: 'var(--c-cloud)',
  NETWORKING: 'var(--c-networking)',
  'SEGURANÇA CIBERNÉTICA': 'var(--c-cyber-security)',
  'CYBER SECURITY': 'var(--c-cyber-security)',
};

function getCategoryColor(category: string): string {
  const normalizedCategory = category.trim().toUpperCase();

  return (
    categoryColors[normalizedCategory] ??
    'var(--accent-hover)'
  );
}

export async function getStaticPaths() {
  const posts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'en',
  );

  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/^en\//, ''),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const hasMermaid = /```mermaid\b/.test(post.body);

const englishSlug = post.id.replace(/^en\//, '');
const postColor = getCategoryColor(post.data.category);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ptHref = post.data.translationOf
  ? `/posts/${post.data.translationOf}/`
  : '/';

const all = (
  await getCollection(
    'posts',
    ({ data }) => !data.draft && data.language === 'en',
  )
)
  .filter((item) => item.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const sameCategory = all.filter(
  (item) => item.data.category === post.data.category,
);

const remainingPosts = all.filter(
  (item) => item.data.category !== post.data.category,
);

const related = [...sameCategory, ...remainingPosts].slice(0, 3);

const seriesPosts = post.data.series
  ? [...all, post]
      .filter((item) => item.data.series === post.data.series)
      .sort((a, b) => (a.data.part ?? a.data.seriesOrder ?? 0) - (b.data.part ?? b.data.seriesOrder ?? 0))
  : [];
const seriesIndex = seriesPosts.findIndex((item) => item.id === post.id);
const previousInSeries = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : undefined;
const nextInSeries = seriesIndex >= 0 ? seriesPosts[seriesIndex + 1] : undefined;
---

<BaseLayout
  lang="en"
  title={`${post.data.title} — CommandLinux`}
  description={post.data.description}
  type="article"
  publishedDate={post.data.date}
  modifiedDate={post.data.updatedDate ?? post.data.date}
  tags={post.data.tags}
  hasMermaid={hasMermaid}
  ogImagePath={`/og/en/${englishSlug}.png`}
  alternatePt={post.data.translationOf ? `/posts/${post.data.translationOf}/` : undefined}
  alternateEn={`/en/posts/${englishSlug}/`}
>
  <Navbar
    language="en"
    ptHref={ptHref}
    enHref={`/en/posts/${englishSlug}/`}
  />

  <div
    class="section-wrap post-page"
    style={`--post-color: ${postColor};`}
  >
    <ReadingProgress label="Reading progress" />
    <a class="post-back" href="/en/">cd ..</a>

    <header class="post-header">
      <span class="post-type">{post.data.category}</span>

      <h1 class="post-title">{post.data.title}</h1>

      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
        <span aria-hidden="true">·</span>
        <a href="/sobre/" rel="author">Cesar Santos</a>
      </div>

      <div class="post-tags" aria-label="Article tags">
        {post.data.tags.map((tag) => (
          <a class="post-tag-link" href={`/en/?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
        ))}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    {post.data.series && (
      <nav class="series-nav" aria-label={`Series ${post.data.series}`}>
        <div class="series-heading">
          <span>// series</span>
          <strong>{post.data.series}</strong>
          <small>Part {post.data.part ?? post.data.seriesOrder ?? seriesIndex + 1} of {post.data.totalParts ?? seriesPosts.length}</small>
        </div>
        <div class="series-links">
          {previousInSeries ? <a href={`/en/posts/${previousInSeries.id.replace(/^en\//, '')}/`}>← {previousInSeries.data.title}</a> : <span />}
          {nextInSeries && <a href={`/en/posts/${nextInSeries.id.replace(/^en\//, '')}/`}>{nextInSeries.data.title} →</a>}
        </div>
      </nav>
    )}

    <ShareButtons client:load title={post.data.title} description={post.data.description} category={post.data.category} locale="en" />
    <Reactions client:load postId={`en:${englishSlug}`} locale="en" />
    <CopyCode />

    {
      related.length > 0 && (
        <section class="related">
          <p class="related-label">// keep reading</p>

          <div class="related-grid">
            {related.map((item) => (
              <a
                class="related-card"
                href={`/en/posts/${item.id.replace(/^en\//, '')}/`}
                style={`--post-color: ${getCategoryColor(
                  item.data.category,
                )};`}
              >
                <span class="related-cat">{item.data.category}</span>
                <span class="related-title">{item.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
