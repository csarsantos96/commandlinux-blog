---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="reading-progress" role="progressbar" aria-label={label} aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
  <span></span>
</div>

<script>
  const progress = document.querySelector<HTMLElement>('.reading-progress');

  if (progress) {
    const bar = progress.querySelector<HTMLElement>('span');
    const updateProgress = () => {
      const article = document.querySelector<HTMLElement>('.post-body');
      if (!article || !bar) return;

      const start = article.offsetTop;
      const distance = Math.max(1, article.offsetHeight - window.innerHeight);
      const value = Math.min(100, Math.max(0, ((window.scrollY - start) / distance) * 100));

      bar.style.transform = `scaleX(${value / 100})`;
      progress.setAttribute('aria-valuenow', String(Math.round(value)));
    };

    updateProgress();
    addEventListener('scroll', updateProgress, { passive: true });
    addEventListener('resize', updateProgress);
  }
</script>

<style>
  .reading-progress {
    position: fixed;
    z-index: 100;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--border);
  }

  .reading-progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--post-color, var(--accent-hover));
    box-shadow: 0 0 10px var(--post-color, var(--accent-hover));
    transform: scaleX(0);
    transform-origin: left;
    will-change: transform;
  }
</style>
