{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "cookie",
          "key": "preferred-language",
          "value": "en"
        }
      ],
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "^(?!(BR|PT|CV|AO)$).*$"
        }
      ],
      "missing": [
        {
          "type": "cookie",
          "key": "preferred-language"
        }
      ],
      "destination": "/en/",
      "permanent": false
    }
  ]
}
